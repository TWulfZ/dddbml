{
  "name": "dddbml",
  "displayName": "dddbml — DBML Diagram with Git-friendly Layout",
  "description": "Interactive DBML diagram renderer for VSCode with per-table position persistence, TableGroup collapse for DDD contexts, and viewport culling for large schemas (5000+ tables).",
  "version": "0.1.2",
  "publisher": "TWulfZ",
  "icon": "docs/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "dbml",
    "diagram",
    "erd",
    "database",
    "schema",
    "ddd"
  ],
  "main": "./dist/extension/extension/extension.js",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TWulfZ/dddbml"
  },
  "homepage": "https://github.com/TWulfZ/dddbml#readme",
  "bugs": {
    "url": "https://github.com/TWulfZ/dddbml/issues"
  },
  "contributes": {
    "commands": [
      {
        "command": "dddbml.openDiagram",
        "title": "dddbml: Open Diagram",
        "category": "dddbml"
      },
      {
        "command": "dddbml.resetLayout",
        "title": "dddbml: Reset Layout (re-run auto-layout)",
        "category": "dddbml"
      },
      {
        "command": "dddbml.pruneOrphans",
        "title": "dddbml: Prune orphan layout entries",
        "category": "dddbml"
      },
      {
        "command": "dddbml.zoomIn",
        "title": "dddbml: Zoom In",
        "category": "dddbml"
      },
      {
        "command": "dddbml.zoomOut",
        "title": "dddbml: Zoom Out",
        "category": "dddbml"
      },
      {
        "command": "dddbml.resetView",
        "title": "dddbml: Reset View",
        "category": "dddbml"
      },
      {
        "command": "dddbml.fitToContent",
        "title": "dddbml: Fit to Content",
        "category": "dddbml"
      }
    ],
    "keybindings": [
      {
        "command": "dddbml.zoomIn",
        "key": "ctrl+=",
        "mac": "cmd+=",
        "when": "activeWebviewPanelId == 'dddbml.diagram'"
      },
      {
        "command": "dddbml.zoomIn",
        "key": "ctrl+shift+=",
        "mac": "cmd+shift+=",
        "when": "activeWebviewPanelId == 'dddbml.diagram'"
      },
      {
        "command": "dddbml.zoomOut",
        "key": "ctrl+-",
        "mac": "cmd+-",
        "when": "activeWebviewPanelId == 'dddbml.diagram'"
      },
      {
        "command": "dddbml.resetView",
        "key": "ctrl+0",
        "mac": "cmd+0",
        "when": "activeWebviewPanelId == 'dddbml.diagram'"
      },
      {
        "command": "dddbml.fitToContent",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'dddbml.diagram'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .dbml",
          "command": "dddbml.openDiagram",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .dbml",
          "command": "dddbml.openDiagram",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "dbml",
        "extensions": [
          ".dbml"
        ],
        "aliases": [
          "DBML",
          "dbml"
        ]
      }
    ]
  },
  "activationEvents": [
    "onLanguage:dbml",
    "onCommand:dddbml.openDiagram"
  ],
  "scripts": {
    "build:extension": "node -e \"require('fs').rmSync('dist/extension',{recursive:true,force:true})\" && esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension/extension.js --external:vscode --platform=node --format=cjs --minify --sourcemap",
    "build:webview": "vite build",
    "build": "pnpm run build:extension && pnpm run build:webview",
    "watch:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dbml/core": "^3.9.0",
    "preact": "^10.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
